# =============================================================================
# Suknaa API — local development environment template
# Copy to .env (gitignored) before running `pnpm --filter api dev`.
# =============================================================================

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ---- CORS (Phase 2.5 M2) ----
# Comma-separated list of allowed browser origins (no spaces required; trimmed when read).
# Add production origins when deploying, e.g. https://suknaa.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- PostgreSQL (matches infrastructure/docker-compose.yml) ----
DATABASE_URL=postgresql://suknaa:suknaa_dev_password@localhost:5432/suknaa_dev?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=suknaa

# ---- Auth rate limits (Phase 2.5 M3; Redis INCR + TTL) ----
# Defaults match env.schema.ts — override only if you need different throttling.
AUTH_RL_LOGIN_MAX=5
AUTH_RL_LOGIN_WINDOW_SEC=60
AUTH_RL_SIGNUP_MAX=3
AUTH_RL_SIGNUP_WINDOW_SEC=3600
AUTH_RL_PASSWORD_RESET_MAX=5
AUTH_RL_PASSWORD_RESET_WINDOW_SEC=3600
AUTH_RL_MFA_MAX=5
AUTH_RL_MFA_WINDOW_SEC=600

# ---- MinIO ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=suknaa_minio
MINIO_SECRET_KEY=suknaa_minio_password
MINIO_KYC_BUCKET=suknaa-kyc

# ---- Messaging (Milestone 3 shared infra) ----
MESSAGE_PROVIDER=mock
DEV_OUTBOX_DIR=.dev-outbox

# =============================================================================
# Below are placeholders — populated in later milestones, validated as optional
# in Milestone 1 so the app can boot for the health check.
# =============================================================================

# ---- JWT (Milestone 4: Auth core, RS256 required) ----
# Local key generation (run once from apps/api):
# mkdir keys
# openssl genrsa -out keys/jwt-private.pem 2048
# openssl rsa -in keys/jwt-private.pem -pubout -out keys/jwt-public.pem
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_MFA_TTL=5m

# ---- OTP + TOTP / 2FA (Milestone 5) ----
OTP_CODE_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_PHONE_RATE_LIMIT_PER_HOUR=3
TWO_FACTOR_ISSUER=Suknaa
TWO_FACTOR_TEMP_SECRET_TTL_SECONDS=600
# 64 hex chars (32 bytes) OR a long passphrase (scrypt-derived key). Required for TOTP at-rest encryption.
# openssl rand -hex 32
TOTP_ENC_KEY=

# ---- WhatsApp Cloud API (optional; keep disabled until Meta onboarding) ----
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_API_VERSION=v21.0

# ---- Internal API key for Next.js BFF → API (Milestone 9) ----
# INTERNAL_API_KEY=

# ---- Super-admin bootstrap (Milestone 4 seed) ----
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
