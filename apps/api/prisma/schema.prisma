// Suknaa — core auth (Phase 2) + vacation rentals (Phase 3 M2). See docs/DATABASE_SCHEMA.md.
//
// DB naming: snake_case tables/columns via @@map / @map.
// Phase 2 partial indexes: see phase2 migration SQL.
// Phase 3 M2 indexes (partial, GiST, child btree, cover unique, CHECK): migration SQL only — no @@index on M2 models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active                 @map("active")
  suspended              @map("suspended")
  pending_verification   @map("pending_verification")
  banned                 @map("banned")

  @@map("user_status")
}

enum UserExperience {
  guest @map("guest")
  host  @map("host")
  admin @map("admin")

  @@map("user_experience")
}

enum HostCategory {
  real_estate   @map("real_estate")
  hospitality @map("hospitality")

  @@map("host_category")
}

enum HostSubtype {
  individual         @map("individual")
  real_estate_office @map("real_estate_office")
  hotel_company      @map("hotel_company")

  @@map("host_subtype")
}

enum WithdrawalSchedule {
  weekly  @map("weekly")
  monthly @map("monthly")
  manual  @map("manual")

  @@map("withdrawal_schedule")
}

enum KycDocType {
  national_id    @map("national_id")
  passport       @map("passport")
  driver_license @map("driver_license")

  @@map("kyc_doc_type")
}

enum KycStatus {
  pending  @map("pending")
  approved @map("approved")
  rejected @map("rejected")
  expired  @map("expired")

  @@map("kyc_status")
}

enum OtpPurpose {
  login                @map("login")
  password_reset       @map("password_reset")
  email_verification   @map("email_verification")
  phone_verification @map("phone_verification")
  two_factor           @map("two_factor")
  change_email         @map("change_email")
  change_phone         @map("change_phone")

  @@map("otp_purpose")
}

enum OtpChannel {
  phone @map("phone")
  email @map("email")

  @@map("otp_channel")
}

model User {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email  String @map("email") @db.VarChar(255)
  emailVerified  Boolean @default(false) @map("email_verified")
  phone  String? @map("phone") @db.VarChar(20)
  phoneVerified  Boolean @default(false) @map("phone_verified")
  passwordHash   String @map("password_hash") @db.VarChar(255)
  fullName       String @map("full_name") @db.VarChar(150)
  avatarUrl      String? @map("avatar_url") @db.VarChar(500)
  preferredLanguage String @default("ar") @map("preferred_language") @db.VarChar(5)
  timezone       String @default("Asia/Damascus") @map("timezone") @db.VarChar(50)

  isGuest      Boolean @default(true) @map("is_guest")
  isHost       Boolean @default(false) @map("is_host")
  isAdmin      Boolean @default(false) @map("is_admin")
  isSuperAdmin Boolean @default(false) @map("is_super_admin")

  lastLoginAs UserExperience @default(guest) @map("last_login_as")
  status      UserStatus      @default(active) @map("status")

  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastLoginIp String?   @map("last_login_ip") @db.Inet

  marketingOptIn Boolean @default(false) @map("marketing_opt_in")

  averageRatingAsGuest Decimal? @map("average_rating_as_guest") @db.Decimal(3, 2)
  totalReviewsAsGuest  Int      @default(0) @map("total_reviews_as_guest")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  hostProfile       HostProfile?
  kycSubmissions    KycSubmission[] @relation("KycSubmissionUser")
  kycReviewed       KycSubmission[] @relation("KycReviewedBy")
  authSessions      AuthSession[]
  otpCodes          OtpCode[]
  twoFactorSecret   TwoFactorSecret?
  auditLogsAsActor         AuditLog[]        @relation("AuditLogActor")
  vacationRentalsHosted    VacationRental[]  @relation("VacationRentalHost")
  vacationRentalsApproved  VacationRental[]  @relation("VacationRentalApprovedBy")

  @@map("users")
}

model HostProfile {
  userId String @id @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  hostCategory HostCategory @map("host_category")
  hostSubtype  HostSubtype  @map("host_subtype")

  displayName          String  @map("display_name") @db.VarChar(200)
  companyName          String? @map("company_name") @db.VarChar(200)
  companyRegistration  String? @map("company_registration") @db.VarChar(100)
  taxId                String? @map("tax_id") @db.VarChar(100)
  bioAr                String? @map("bio_ar")
  bioEn                String? @map("bio_en")

  responseRate       Int? @map("response_rate") @db.SmallInt
  responseTimeMinutes Int? @default(0) @map("response_time_minutes")
  acceptanceRate     Int? @map("acceptance_rate") @db.SmallInt

  reTotalListings Int @default(0) @map("re_total_listings")
  hotelTotal      Int @default(0) @map("hotel_total")
  totalBookings   Int @default(0) @map("total_bookings")

  averageRating Decimal? @map("average_rating") @db.Decimal(3, 2)
  totalReviews  Int      @default(0) @map("total_reviews")

  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(3)

  withdrawalSchedule WithdrawalSchedule @default(monthly) @map("withdrawal_schedule")
  bankDetailsEncrypted String? @map("bank_details_encrypted")

  suspiciousActivityScore Int       @default(0) @map("suspicious_activity_score") @db.SmallInt
  lastFlaggedAt           DateTime? @map("last_flagged_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("host_profiles")
}

model KycSubmission {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation("KycSubmissionUser", fields: [userId], references: [id], onDelete: Restrict)

  intendedHostCategory HostCategory? @map("intended_host_category")
  intendedHostSubtype  HostSubtype?  @map("intended_host_subtype")

  idDocumentType KycDocType @map("id_document_type")
  idFrontUrl     String     @map("id_front_url") @db.VarChar(500)
  idBackUrl      String?    @map("id_back_url") @db.VarChar(500)
  selfieUrl      String     @map("selfie_url") @db.VarChar(500)

  ownershipProofUrl        String? @map("ownership_proof_url") @db.VarChar(500)
  companyRegistrationUrl   String? @map("company_registration_url") @db.VarChar(500)
  taxCertificateUrl        String? @map("tax_certificate_url") @db.VarChar(500)
  authorizationLetterUrl   String? @map("authorization_letter_url") @db.VarChar(500)
  hotelLicenseUrl          String? @map("hotel_license_url") @db.VarChar(500)

  status           KycStatus @default(pending) @map("status")
  rejectionReason  String?   @map("rejection_reason")
  reviewedByUserId String?   @map("reviewed_by") @db.Uuid
  reviewedByUser   User?     @relation("KycReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz(3)
  submittedAt      DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(3)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(3)

  @@index([status, submittedAt(sort: Desc)], map: "idx_kyc_submissions_admin_queue")
  @@map("kyc_submissions")
}

model AuthSession {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String @map("refresh_token_hash") @db.VarChar(128)
  loginIntent      UserExperience @map("login_intent")
  rememberMe       Boolean        @default(false) @map("remember_me")

  userAgent String? @map("user_agent")
  ipAddress String? @map("ip_address") @db.Inet

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(3)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(3)

  /// Partial index idx_auth_sessions_active_by_user: see migration SQL (revoked_at IS NULL).
  @@index([userId], map: "idx_auth_sessions_user_id")
  @@map("auth_sessions")
}

model OtpCode {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  purpose OtpPurpose @map("purpose")
  channel OtpChannel @map("channel")

  /// Normalized destination for indexing (E.164 phone or lowercased email).
  deliveryTarget String @map("delivery_target") @db.VarChar(255)
  codeHash       String @map("code_hash") @db.VarChar(255)

  attemptsCount Int       @default(0) @map("attempts_count") @db.SmallInt
  lockedUntil   DateTime? @map("locked_until") @db.Timestamptz(3)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt    DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([userId, createdAt(sort: Desc)], map: "idx_otp_codes_user_created")
  @@index([deliveryTarget, channel, createdAt(sort: Desc)], map: "idx_otp_codes_rate_limit")
  @@index([expiresAt], map: "idx_otp_codes_expires_at")
  @@map("otp_codes")
}

model TwoFactorSecret {
  userId String @id @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totpSecretEncrypted String? @map("totp_secret_encrypted")
  backupCodesHashes   Json    @default("[]") @map("backup_codes_hashes")

  enabledAt  DateTime? @map("enabled_at") @db.Timestamptz(3)
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("two_factor_secrets")
}

model AuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorUser   User?   @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  actorRole String? @map("actor_role") @db.VarChar(50)
  actorIp   String? @map("actor_ip") @db.Inet
  userAgent String? @map("user_agent")
  requestId String? @map("request_id") @db.VarChar(100)

  action     String  @map("action") @db.VarChar(120)
  entityType String  @map("entity_type") @db.VarChar(120)
  entityId   String? @map("entity_id") @db.Uuid

  beforeJson Json? @map("before") @db.JsonB
  afterJson  Json? @map("after") @db.JsonB
  metadata Json @map("metadata") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([actorUserId, createdAt(sort: Desc)], map: "idx_audit_logs_actor_created")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

// --- Phase 3 M2: Vacation rentals / holiday homes (docs/DATABASE_SCHEMA.md §B0) ---

enum VacationRentalType {
  apartment @map("apartment")
  house     @map("house")
  villa     @map("villa")
  farm      @map("farm")
  chalet    @map("chalet")
  cabin     @map("cabin")
  studio    @map("studio")

  @@map("vacation_rental_type")
}

enum VacationRentalListingStatus {
  draft          @map("draft")
  pending_review @map("pending_review")
  published      @map("published")
  paused         @map("paused")
  rejected       @map("rejected")
  archived       @map("archived")

  @@map("vacation_rental_listing_status")
}

enum LocationPrecision {
  precise     @map("precise")
  approximate @map("approximate")

  @@map("location_precision")
}

enum BookingMode {
  instant      @map("instant")
  request      @map("request")
  contact_only @map("contact_only")

  @@map("booking_mode")
}

enum CancellationPolicy {
  flexible @map("flexible")
  medium   @map("medium")
  strict   @map("strict")

  @@map("cancellation_policy")
}

enum SpaceType {
  bedroom     @map("bedroom")
  bathroom    @map("bathroom")
  kitchen     @map("kitchen")
  living_room @map("living_room")
  dining_room @map("dining_room")
  balcony     @map("balcony")
  terrace     @map("terrace")
  garden      @map("garden")
  pool_area   @map("pool_area")
  rooftop     @map("rooftop")
  parking     @map("parking")
  storage     @map("storage")
  office      @map("office")
  gym         @map("gym")
  other       @map("other")

  @@map("space_type")
}

enum BathroomType {
  full         @map("full")
  half         @map("half")
  shower_only  @map("shower_only")
  wc_only      @map("wc_only")

  @@map("bathroom_type")
}

enum AmenityCategory {
  essentials     @map("essentials")
  kitchen        @map("kitchen")
  bathroom       @map("bathroom")
  bedroom        @map("bedroom")
  living         @map("living")
  outdoor        @map("outdoor")
  pool_spa       @map("pool_spa")
  parking        @map("parking")
  safety         @map("safety")
  family         @map("family")
  accessibility  @map("accessibility")
  work           @map("work")
  entertainment  @map("entertainment")
  services       @map("services")

  @@map("amenity_category")
}

enum AvailabilityReason {
  booked         @map("booked")
  host_blocked   @map("host_blocked")
  maintenance    @map("maintenance")

  @@map("availability_reason")
}

enum SeasonType {
  summer          @map("summer")
  winter          @map("winter")
  eid             @map("eid")
  ramadan         @map("ramadan")
  new_year        @map("new_year")
  school_holiday  @map("school_holiday")
  custom          @map("custom")

  @@map("season_type")
}

model VacationRental {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostId      String              @map("host_id") @db.Uuid
  host        User                @relation("VacationRentalHost", fields: [hostId], references: [id], onDelete: Restrict)
  rentalType  VacationRentalType  @map("rental_type")

  titleAr       String  @map("title_ar") @db.VarChar(200)
  titleEn       String? @map("title_en") @db.VarChar(200)
  descriptionAr String  @map("description_ar")
  descriptionEn String? @map("description_en")

  countryCode        String            @default("SY") @map("country_code") @db.Char(2)
  governorate        String            @map("governorate") @db.VarChar(100)
  city               String            @map("city") @db.VarChar(100)
  neighborhood       String?           @map("neighborhood") @db.VarChar(150)
  addressLine        String?           @map("address_line") @db.VarChar(255)
  location           Unsupported("geography(Point,4326)") @map("location")
  locationPrecision  LocationPrecision @default(approximate) @map("location_precision")

  maxGuests      Int     @map("max_guests") @db.SmallInt
  bedroomsCount  Int     @default(0) @map("bedrooms_count") @db.SmallInt
  bedsCount      Int     @default(0) @map("beds_count") @db.SmallInt
  bathroomsCount Decimal @default(1.0) @map("bathrooms_count") @db.Decimal(3, 1)
  areaSqm        Int?    @map("area_sqm")

  basePriceCents    BigInt  @map("base_price_cents")
  weeklyPriceCents  BigInt? @map("weekly_price_cents")
  monthlyPriceCents BigInt? @map("monthly_price_cents")
  weekendUpliftPct  Int     @default(0) @map("weekend_uplift_pct") @db.SmallInt
  cleaningFeeCents  BigInt  @default(0) @map("cleaning_fee_cents")
  minimumStayNights Int     @default(1) @map("minimum_stay_nights") @db.SmallInt
  maximumStayNights Int?    @map("maximum_stay_nights") @db.SmallInt
  currency          String  @default("USD") @map("currency") @db.Char(3)

  commissionPassthrough Boolean            @default(false) @map("commission_passthrough")
  bookingMode           BookingMode        @default(request) @map("booking_mode")
  cancellationPolicy    CancellationPolicy @map("cancellation_policy")

  status              VacationRentalListingStatus @default(draft) @map("status")
  rejectionReason     String?                     @map("rejection_reason")
  submittedForReviewAt DateTime?                   @map("submitted_for_review_at") @db.Timestamptz(3)
  approvedAt          DateTime?                   @map("approved_at") @db.Timestamptz(3)
  approvedByUserId    String?                     @map("approved_by") @db.Uuid
  approvedByUser      User?                       @relation("VacationRentalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  totalBookings                  Int      @default(0) @map("total_bookings")
  totalViews                     Int      @default(0) @map("total_views")
  averageRating                  Decimal? @map("average_rating") @db.Decimal(3, 2)
  totalReviews                   Int      @default(0) @map("total_reviews")
  lastAvailabilityReductionAt    DateTime? @map("last_availability_reduction_at") @db.Timestamptz(3)
  availabilityReductionsCount    Int      @default(0) @map("availability_reductions_count")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  spaces              VacationRentalSpace[]
  images              VacationRentalImage[]
  amenities           VacationRentalAmenity[]
  availabilityBlocks  VacationRentalAvailabilityBlock[]
  pricingOverrides    VacationRentalPricingOverride[]

  @@map("vacation_rentals")
}

model VacationRentalSpace {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vacationRentalId  String         @map("vacation_rental_id") @db.Uuid
  vacationRental    VacationRental @relation(fields: [vacationRentalId], references: [id], onDelete: Cascade)

  spaceType     SpaceType @map("space_type")
  labelAr       String    @map("label_ar") @db.VarChar(100)
  labelEn       String?   @map("label_en") @db.VarChar(100)
  descriptionAr String?   @map("description_ar")
  descriptionEn String?   @map("description_en")
  sortOrder     Int       @default(0) @map("sort_order")

  beds          Json?         @map("beds") @db.JsonB
  hasEnsuite    Boolean?      @map("has_ensuite")
  bathroomType  BathroomType? @map("bathroom_type")
  isShared      Boolean?      @map("is_shared")
  areaSqm       Int?          @map("area_sqm")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  images    VacationRentalSpaceImage[]
  amenities VacationRentalSpaceAmenity[]

  @@map("vacation_rental_spaces")
}

model VacationRentalImage {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vacationRentalId String         @map("vacation_rental_id") @db.Uuid
  vacationRental   VacationRental @relation(fields: [vacationRentalId], references: [id], onDelete: Cascade)

  storageKey  String  @map("storage_key") @db.VarChar(500)
  urlOriginal String  @map("url_original") @db.VarChar(500)
  urlLarge    String  @map("url_large") @db.VarChar(500)
  urlMedium   String  @map("url_medium") @db.VarChar(500)
  urlSmall    String  @map("url_small") @db.VarChar(500)
  width       Int?
  height      Int?
  altTextAr   String? @map("alt_text_ar") @db.VarChar(255)
  altTextEn   String? @map("alt_text_en") @db.VarChar(255)
  sortOrder   Int     @default(0) @map("sort_order")
  isCover     Boolean @default(false) @map("is_cover")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("vacation_rental_images")
}

model VacationRentalSpaceImage {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vacationRentalSpaceId String              @map("vacation_rental_space_id") @db.Uuid
  vacationRentalSpace   VacationRentalSpace @relation(fields: [vacationRentalSpaceId], references: [id], onDelete: Cascade)

  storageKey  String  @map("storage_key") @db.VarChar(500)
  urlOriginal String  @map("url_original") @db.VarChar(500)
  urlLarge    String  @map("url_large") @db.VarChar(500)
  urlMedium   String  @map("url_medium") @db.VarChar(500)
  urlSmall    String  @map("url_small") @db.VarChar(500)
  width       Int?
  height      Int?
  altTextAr   String? @map("alt_text_ar") @db.VarChar(255)
  altTextEn   String? @map("alt_text_en") @db.VarChar(255)
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("vacation_rental_space_images")
}

model Amenity {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code     String @unique @db.VarChar(50)
  nameAr   String @map("name_ar") @db.VarChar(100)
  nameEn   String @map("name_en") @db.VarChar(100)
  iconName String? @map("icon_name") @db.VarChar(50)
  category AmenityCategory @map("category")

  appliesToVacationRental      Boolean @default(true) @map("applies_to_vacation_rental")
  appliesToVacationRentalSpace Boolean @default(false) @map("applies_to_vacation_rental_space")
  appliesToHotel               Boolean @default(false) @map("applies_to_hotel")
  appliesToRoomType            Boolean @default(false) @map("applies_to_room_type")

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  vacationRentals      VacationRentalAmenity[]
  vacationRentalSpaces VacationRentalSpaceAmenity[]

  @@map("amenities")
}

model VacationRentalAmenity {
  vacationRentalId String         @map("vacation_rental_id") @db.Uuid
  vacationRental   VacationRental @relation(fields: [vacationRentalId], references: [id], onDelete: Cascade)
  amenityId        String         @map("amenity_id") @db.Uuid
  amenity          Amenity        @relation(fields: [amenityId], references: [id], onDelete: Restrict)

  @@id([vacationRentalId, amenityId])
  @@map("vacation_rental_amenities")
}

model VacationRentalSpaceAmenity {
  vacationRentalSpaceId String              @map("vacation_rental_space_id") @db.Uuid
  vacationRentalSpace   VacationRentalSpace @relation(fields: [vacationRentalSpaceId], references: [id], onDelete: Cascade)
  amenityId             String              @map("amenity_id") @db.Uuid
  amenity               Amenity             @relation(fields: [amenityId], references: [id], onDelete: Restrict)

  @@id([vacationRentalSpaceId, amenityId])
  @@map("vacation_rental_space_amenities")
}

model VacationRentalAvailabilityBlock {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vacationRentalId String             @map("vacation_rental_id") @db.Uuid
  vacationRental   VacationRental     @relation(fields: [vacationRentalId], references: [id], onDelete: Cascade)

  startsOn  DateTime           @map("starts_on") @db.Date
  endsOn    DateTime           @map("ends_on") @db.Date
  reason    AvailabilityReason @map("reason")
  bookingId String?            @map("booking_id") @db.Uuid
  note      String?            @map("note")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("vacation_rental_availability_blocks")
}

model VacationRentalPricingOverride {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vacationRentalId String         @map("vacation_rental_id") @db.Uuid
  vacationRental   VacationRental @relation(fields: [vacationRentalId], references: [id], onDelete: Cascade)

  startsOn DateTime @map("starts_on") @db.Date
  endsOn   DateTime @map("ends_on") @db.Date

  basePriceCents    BigInt  @map("base_price_cents")
  weeklyPriceCents  BigInt? @map("weekly_price_cents")
  monthlyPriceCents BigInt? @map("monthly_price_cents")

  labelAr    String?     @map("label_ar") @db.VarChar(100)
  labelEn    String?     @map("label_en") @db.VarChar(100)
  seasonType SeasonType? @map("season_type")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("vacation_rental_pricing_overrides")
}
