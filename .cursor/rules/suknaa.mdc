## 9. Common Patterns

### Database query
```typescript
// ❌ Don't
const user = await prisma.user.findFirst({ where: { id } });
if (user.is_host) { ... }   // could be undefined

// ✅ Do
const user = await prisma.user.findUniqueOrThrow({ where: { id } });
if (user.isHost) { ... }
```

### Money calculation
```typescript
// ❌ Don't
const total = nightly * nights + 5.99;  // float disaster

// ✅ Do
import { calculateBookingPrice } from '@suknaa/pricing';
const result = calculateBookingPrice({ ... });
// result.guestTotalCents (bigint)
```

### Auth check
```typescript
// ❌ Don't (only checks at controller)
@Get(':id')
@UseGuards(JwtAuthGuard)
async getVacationRental(@Param('id') id: string) { ... }

// ✅ Do (also check at service)
async getVacationRentalForUser(vacationRentalId: string, userId: string) {
  const vacationRental = await prisma.vacationRental.findUniqueOrThrow({ where: { id: vacationRentalId } });
  if (vacationRental.hostId !== userId) {
    throw new ForbiddenException({ code: 'NOT_VACATION_RENTAL_OWNER' });
  }
  return vacationRental;
}
```

### Category check (NEW v2)
```typescript
// When a host calls a hotel-specific endpoint, verify they're a hotel host
async createHotel(dto: CreateHotelDto, userId: string) {
  const profile = await prisma.hostProfile.findUniqueOrThrow({ where: { userId } });
  if (profile.hostCategory !== 'hospitality') {
    throw new ForbiddenException({ code: 'WRONG_HOST_CATEGORY' });
  }
  // ... create hotel
}
```

### Polymorphic booking
```typescript
async getBookingDetails(bookingId: string) {
  const booking = await prisma.booking.findUniqueOrThrow({ where: { id: bookingId } });
  if (booking.kind === 'vacation_rentals') {
    return {
      ...booking,
      vacationRental: await prisma.vacationRental.findUnique({ where: { id: booking.vacationRentalId! } }),
    };
  } else {
    return {
      ...booking,
      hotel: await prisma.hotel.findUnique({ where: { id: booking.hotelId! } }),
      roomType: await prisma.roomType.findUnique({ where: { id: booking.roomTypeId! } }),
    };
  }
}
```
*(Until Prisma models exist, generated client may still expose legacy `propertyId` — **legacy pre-M2/M2b inventory**; new code must use `vacationRentalId` / `VacationRental`.)*

### Form validation (shared schema)
```typescript
// Target: packages/types/src/schemas/vacation-rental.ts (legacy filename `property.ts` = pre-M2/M2b inventory only)
export const createVacationRentalSchema = z.object({
  titleAr: z.string().min(5).max(200),
  basePriceCents: z.bigint().positive(),
  // ...
});
// Used in apps/web (React Hook Form) AND apps/api (DTO validation)
```

